# ==========================================================================
# jobs-mrk — exemplo de variáveis de ambiente
# Copie para `.env` e preencha. NUNCA commitar o .env real (já está no .gitignore).
# ==========================================================================

# --- Aplicação ---
NODE_ENV=production
PORT=3005

# --- Banco de dados (MySQL) ---
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
# Limite de conexões do pool (default 10)
DB_POOL_LIMIT=10

# --- Observabilidade (OpenTelemetry / SigNoz) ---
# Liga/desliga toda a stack. false => app roda idêntico ao original (sem traces/logs/métricas OTLP).
OTEL_ENABLED=true
# Endpoint OTLP do SigNoz (base; os paths /v1/traces|logs|metrics são anexados automaticamente).
# Porta 4318 = ingest OTLP/HTTP do SigNoz. A raiz :443 (https) serve a UI e NÃO aceita OTLP (405).
# Ideal: expor via HTTPS (proxy reverso para /v1/*) e usar https aqui.
OTEL_EXPORTER_OTLP_ENDPOINT=http://monitor.mrksolucoes.com.br:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Headers extras para o OTLP, se necessário (ex.: "Authorization=Bearer xxx").
OTEL_EXPORTER_OTLP_HEADERS=
# Nome do serviço (definido por processo no ecosystem: jobs-mrk-api|scheduler|consumer).
OTEL_SERVICE_NAME=jobs-mrk
OTEL_SERVICE_VERSION=
# Atributos extras de resource (ex.: "team=plataforma,deployment.environment=producao").
OTEL_RESOURCE_ATTRIBUTES=
# Intervalo de export de métricas em ms (default 60000).
OTEL_METRIC_EXPORT_INTERVAL=60000
# Nível mínimo de log: trace|debug|info|warn|error|fatal|silent (default info em prod).
LOG_LEVEL=info

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_WHATSAPP=whatsapp_messages
RABBITMQ_QUEUE_TELEMETRIA=telemetria_logs

# --- Backend PHP (Portal MRK) ---
BACKEND_URL=
MRK_TOKEN=

# --- Integração Menew ---
MENEW_URL=

# --- Integração Zig ---
ZIG_URL_INTEGRATION=

# --- Z-API (WhatsApp) ---
ZAPI_BASE_URL=
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- TecnoSpeed / Pluggy (Open Finance) ---
TECNOSPEED_API_URL=
TECNOSPEED_CNPJ_SH=
TECNOSPEED_TOKEN_SH=

# --- iFood ---
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_AMBIENTE=PRODUCAO
IFOOD_JANELA_DIAS=

# --- Dashboard (auth simples) ---
DASH_USER=
DASH_PASS=

# --- Diversos ---
GROUP_ID=
ID_DISPARO_COP=
PUBLIC_BASE_REPORT_URL=
